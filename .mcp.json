{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "vector-memory": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "--bun",
        "@aeriondyseti/vector-memory-mcp@rc",
        "--enable-history"
      ]
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--mode",
        "no-memories",
        "--context",
        "ide-assistant",
        "--project",
        "/home/aerion/dev/vector-memory-mcp"
      ]
    }
  }
}