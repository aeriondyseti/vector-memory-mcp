{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claude-code-marketplace.schema.json",
  "title": "Claude Code Plugin Marketplace",
  "description": "Schema for .claude-plugin/marketplace.json — defines a plugin marketplace catalog.",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Marketplace identifier (kebab-case, no spaces). Public-facing: users see it when installing plugins."
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "Source code repository URL."
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the maintainer or team."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Contact email for the maintainer."
        }
      },
      "additionalProperties": false,
      "description": "Marketplace maintainer information."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "description": "Brief marketplace description."
        },
        "version": {
          "type": "string",
          "description": "Marketplace version."
        },
        "pluginRoot": {
          "type": "string",
          "description": "Base directory prepended to relative plugin source paths."
        }
      },
      "additionalProperties": false,
      "description": "Optional marketplace metadata."
    },
    "plugins": {
      "type": "array",
      "description": "List of available plugins.",
      "items": {
        "$ref": "#/$defs/pluginEntry"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "pluginSource": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\./",
          "description": "Relative path within the marketplace repo. Must start with ./"
        },
        {
          "type": "object",
          "required": ["source", "repo"],
          "properties": {
            "source": { "const": "github" },
            "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$", "description": "GitHub repo in owner/repo format." },
            "ref": { "type": "string", "description": "Git branch or tag." },
            "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$", "description": "Full 40-character git commit SHA." }
          },
          "additionalProperties": false,
          "description": "GitHub repository source."
        },
        {
          "type": "object",
          "required": ["source", "url"],
          "properties": {
            "source": { "const": "url" },
            "url": { "type": "string", "format": "uri", "description": "Full git repository URL." },
            "ref": { "type": "string" },
            "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
          },
          "additionalProperties": false,
          "description": "Git URL source."
        },
        {
          "type": "object",
          "required": ["source", "url", "path"],
          "properties": {
            "source": { "const": "git-subdir" },
            "url": { "type": "string", "description": "Git repository URL, GitHub owner/repo shorthand, or SSH URL." },
            "path": { "type": "string", "description": "Subdirectory path within the repo containing the plugin." },
            "ref": { "type": "string" },
            "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
          },
          "additionalProperties": false,
          "description": "Subdirectory within a git repo (sparse clone)."
        },
        {
          "type": "object",
          "required": ["source", "package"],
          "properties": {
            "source": { "const": "npm" },
            "package": { "type": "string", "description": "npm package name or scoped package." },
            "version": { "type": "string", "description": "Version or version range." },
            "registry": { "type": "string", "format": "uri", "description": "Custom npm registry URL." }
          },
          "additionalProperties": false,
          "description": "npm package source."
        }
      ]
    },
    "pathOrPaths": {
      "oneOf": [
        { "type": "string", "pattern": "^\\./" },
        { "type": "array", "items": { "type": "string", "pattern": "^\\./" } }
      ]
    },
    "pathOrPathsOrObject": {
      "oneOf": [
        { "type": "string", "pattern": "^\\./" },
        { "type": "array", "items": { "type": "string", "pattern": "^\\./" } },
        { "type": "object" }
      ]
    },
    "pluginEntry": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Plugin identifier (kebab-case, no spaces)."
        },
        "source": {
          "$ref": "#/$defs/pluginSource",
          "description": "Where to fetch the plugin from."
        },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "author": { "$ref": "#/$defs/author" },
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "license": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string", "description": "Plugin category for organization." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for searchability." },
        "strict": {
          "type": "boolean",
          "default": true,
          "description": "Controls whether plugin.json is the authority for component definitions. Default: true."
        },
        "commands": { "$ref": "#/$defs/pathOrPaths" },
        "agents": { "$ref": "#/$defs/pathOrPaths" },
        "hooks": { "$ref": "#/$defs/pathOrPathsOrObject" },
        "mcpServers": { "$ref": "#/$defs/pathOrPathsOrObject" },
        "lspServers": { "$ref": "#/$defs/pathOrPathsOrObject" }
      },
      "additionalProperties": false
    }
  }
}
